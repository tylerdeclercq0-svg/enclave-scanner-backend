# Copy this to .env for local testing (Render/Railway: set these in their dashboard instead)

# Free key from https://api.census.gov/data/key_signup.html — required
# for the on-demand area demographics feature. Not required for basic
# county scanning.
CENSUS_API_KEY=

# Your deployed Netlify frontend URL, e.g. https://falconegroupmapping.netlify.app
# Used to restrict CORS so only your frontend can call this API.
# Leave as * only for local testing.
FRONTEND_ORIGIN=*
